{
  "expo": {
    "name": "ProjectLightHouseReactApp",
    "slug": "ProjectLightHouseReactApp",
    "scheme": "projectlighthouse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false, 
    "packagerOpts": {
      "config": "metro.config.js",
      "sourceExts": ["js", "jsx", "json", "ts", "tsx", "bin"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jmb10.ProjectLightHouseReactApp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app needs camera access to classify images for Project Lighthouse."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jmb10.ProjectLightHouseReactApp"
    },
    "extra": {
      "eas": {
        "projectId": "8e70bcba-5878-4373-8088-14cf29429b38"
      }
    }
  }
}
